# Azure Storage connection defaults for local Azurite emulator
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==

# Table and Container Names
AZURE_TABLE_NAME=UploadRequestsV2
AZURE_SHARE_TABLE_NAME=DownloadShares
AZURE_BLOB_CONTAINER_NAME=uploads

# Azure Emulator URLs (optional for local usage)
AZURE_TABLE_URL=http://127.0.0.1:10002/devstoreaccount1
AZURE_BLOB_URL=http://127.0.0.1:10000/devstoreaccount1

# Server Port and Frontend URL
PORT=3001
FRONTEND_URL=http://localhost:5173

# Integrations
GCNOTIFY_API_KEY=mock-key-for-local-dev
GCNOTIFY_TEMPLATE_ID=mock-template-id
ASSEMBLYLINE_URL=mock

# MSAL Federation (Backend Validation)
MSAL_CLIENT_ID=enter-your-entra-id-client-id-here
MSAL_TENANT_ID=enter-your-entra-id-tenant-id-here
MSAL_EXPECTED_AUD=
MSAL_REDIRECT_URI=http://localhost:3001/auth/redirect

# SMTP Mailer Configuration
MAILER_ENABLED=false
MAILER_SMTP_ADDR=email-smtp.ca-central-1.amazonaws.com
MAILER_SMTP_PORT=587
MAILER_FROM=noreply@example.com
MAILER_USER=your-smtp-username
MAILER_PASSWD=your-smtp-password
